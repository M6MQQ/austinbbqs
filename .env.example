# PostgreSQL connection string (Railway Postgres provides this automatically)
DATABASE_URL="postgresql://user:password@localhost:5432/austinbbqs?schema=public"

# Admin login password (choose a strong value)
ADMIN_PASSWORD="change-me"

# Secret used to sign the admin session cookie (32+ random chars)
SESSION_SECRET="generate-a-long-random-string-here"

# Anthropic API key for the AI research chat
ANTHROPIC_API_KEY="sk-ant-..."

# Directory where uploaded images are stored.
# On Railway, mount a Volume at /data and set this to /data/uploads.
# Locally it defaults to ./.data/uploads if unset.
UPLOAD_DIR="/data/uploads"

# Public site URL (used for canonical links, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL="https://austinbbqs.com"
